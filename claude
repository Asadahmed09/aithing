      "from collections import deque",
      "",
      "def bfs(graph, start, goal):",
      "    q = deque([start])",
      "    vis = set()",
      "    while q:",
      "        n = q.popleft()",
      "        if n == goal:",
      "            print('Found')",
      "            return",
      "        if n not in vis:",
