  "BFS": {
    "prefix": "bfs",
    "body": [
      "from collections import deque",
      "",
      "def bfs(graph, start, goal):",
      "    q = deque([start])",
      "    vis = set()",
      "    while q:",
      "        n = q.popleft()",
      "        if n == goal:",
      "            print('Found')",
      "            return",
      "        if n not in vis:",
      "            vis.add(n)",
      "            for nei in graph[n]:",
      "                q.append(nei)"
    ],
    "description": "Breadth First Search — level-by-level, complete & optimal (unweighted)"
  },

  "DFS": {
    "prefix": "dfs",
    "body": [
      "def dfs(graph, node, goal, vis=None):",
      "    if vis is None: vis = set()",
      "    if node == goal:",
      "        print('Found')",
      "        return True",
      "    vis.add(node)",
      "    for nei in graph[node]:",
      "        if nei not in vis:",
      "            if dfs(graph, nei, goal, vis):",
      "                return True",
      "    return False"
    ],
    "description": "Depth First Search — recursive, uses call stack, not optimal"
  },

  "DLS": {
    "prefix": "dls",
    "body": [
      "def dls(node, goal, depth, limit, graph):",
      "    if node == goal:",
      "        print('Found')",
      "        return True",
      "    if depth == limit:",
      "        return False          # cutoff",
      "    for nei in graph[node]:",
      "        if dls(nei, goal, depth + 1, limit, graph):",
      "            return True",
      "    return False"
    ],
    "description": "Depth Limited Search — DFS with depth cap, needed for IDDFS"
  },

