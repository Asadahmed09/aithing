      "q_table = {}",
      "ALPHA = 0.1    # learning rate",
      "GAMMA = 0.9    # discount factor",
      "",
      "def learn(state, reward, next_state):",
      "    q_table.setdefault(state, 0)",
      "    q_table.setdefault(next_state, 0)",
      "    q_table[state] += ALPHA * (",
      "        reward + GAMMA * q_table[next_state] - q_table[state]",
      "    )",
      "",
      "def choose_action(state, actions):",
      "    # greedy: pick action with highest Q-value",
      "    return max(actions, key=lambda a: q_table.get(a, 0))"
    ],
    "description": "Learning Based Agent — Q-update: Q(s) += α(r + γ·maxQ − Q(s))"
