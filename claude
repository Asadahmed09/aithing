 "Genetic Algorithm": {
    "prefix": "genetic",
    "body": [
      "import random",
      "",
      "# ── config ──────────────────────────────────────",
      "GENE_LENGTH   = 5       # bits per chromosome",
      "POP_SIZE      = 6       # individuals in population",
      "GENERATIONS   = 10      # iterations",
      "MUTATION_RATE = 0.1     # 10% chance per bit",
      "",
      "# ── encoding & fitness ───────────────────────────",
      "def decode(chrom):",
      "    return int(chrom, 2)          # binary string -> int",
      "",
      "def fitness(chrom):",
      "    x = decode(chrom)",
      "    return x ** 2                 # CHANGE THIS for your problem",
      "",
      "# ── initialization ───────────────────────────────",
      "def init_population():",
      "    pop = []",
      "    for _ in range(POP_SIZE):",
      "        chrom = ''.join(random.choice('01') for _ in range(GENE_LENGTH))",
      "        pop.append(chrom)",
      "    return pop",
      "",
      "# ── selection (roulette wheel) ────────────────────",
      "def select(pop):",
      "    scores = [fitness(c) for c in pop]",
      "    total  = sum(scores)",
      "    probs  = [s / total for s in scores]",
      "    p1 = random.choices(pop, weights=probs)[0]",
      "    p2 = random.choices(pop, weights=probs)[0]",
      "    return p1, p2",
      "",
      "# ── selection (tournament) — alternative ─────────",
      "def tournament_select(pop, k=3):",
      "    contestants = random.sample(pop, k)",
      "    return max(contestants, key=fitness)",
      "",
      "# ── crossover (single-point) ──────────────────────",
      "def crossover(p1, p2, rate=0.9):",
      "    if random.random() > rate:",
      "        return p1, p2             # no crossover this round",
      "    point  = random.randint(1, len(p1) - 1)",
      "    child1 = p1[:point] + p2[point:]",
      "    child2 = p2[:point] + p1[point:]",
      "    return child1, child2",
      "",
      "# ── mutation (bit-flip) ───────────────────────────",
      "def mutate(chrom, rate=MUTATION_RATE):",
      "    result = ''",
      "    for bit in chrom:",
      "        if random.random() < rate:",
      "            result += '1' if bit == '0' else '0'  # flip",
      "        else:",
      "            result += bit                          # keep",
      "    return result",
      "",
      "# ── main generational loop ────────────────────────",
      "def genetic_algorithm():",
      "    pop = init_population()",
      "    print(f'Initial population: {pop}')",
      "",
      "    for gen in range(GENERATIONS):",
      "        # elitism: best individual survives unchanged",
      "        best    = max(pop, key=fitness)",
      "        new_pop = [best]",
      "",
      "        while len(new_pop) < POP_SIZE:",
      "            p1, p2 = select(pop)",
      "            c1, c2 = crossover(p1, p2)",
      "            c1 = mutate(c1)",
      "            c2 = mutate(c2)",
      "            new_pop.extend([c1, c2])",
      "",
      "        pop = new_pop[:POP_SIZE]",
      "",
      "        best     = max(pop, key=fitness)",
      "        best_val = decode(best)",
      "        best_fit = fitness(best)",
      "        print(f'Gen {gen+1:2d} | best: {best} | x={best_val} | fitness={best_fit}')",
      "",
      "    final = max(pop, key=fitness)",
      "    print(f'Answer: x = {decode(final)}, fitness = {fitness(final)}')",
      "    return final",
      "",
      "genetic_algorithm()"
    ],
    "description": "Genetic Algorithm COMPLETE — encode, fitness, init, roulette+tournament selection, crossover, mutation, elitism"
  },

