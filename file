  "BFS":
  {
    "prefix": "bfs",
    "body": [
      "from collections import deque",
      "def bfs(graph, start, goal):",
      "    q = deque([start])",
      "    vis = set()",
      "    while q:",
      "        n = q.popleft()",
      "        if n == goal:",
      "            print('Found')",
      "            return",
      "        if n not in vis:",
      "            vis.add(n)",
      "            for nei in graph[n]:",
      "                q.append(nei)"
    ],
    "description": "Breadth First Search"
  },

