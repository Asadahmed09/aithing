      "t.display_info()",
      "t.teach()",
      "",
      "print('\\n═══ Admin Staff ═══')",
      "a.display_info()",
      "a.perform_task()",
      "",
      "print('\\n═══ Research Assistant ═══')",
      "ra.display_info()",
      "ra.work_on_research()"
    ],
    "description": "Practice Task 2 — University Staff Management System"
