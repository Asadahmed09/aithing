  "3.1 Inheritance without super()": {
    "prefix": "oop-inherit-no-super",
    "body": [
      "# Parent class",
      "class Person:",
      "    def __init__(self, name, age):",
      "        self.name = name",
      "        self.age  = age",
      "",
      "    def display_person(self):",
      "        print(f'Name: {self.name}, Age: {self.age}')",
      "",
      "# Child class — no __init__, inherits parent's automatically",
      "class Student(Person):",
      "    def display_student(self):",
      "        print('This is a student')",
      "",
      "s1 = Student('Ali', 16)",
      "s1.display_person()   # inherited from parent",
      "s1.display_student()  # child's own method"
    ],
    "description": "3.1 — Inheritance without super()"
  },

  "3.2 Inheritance with super()": {
    "prefix": "oop-inherit-super",
    "body": [
      "# Parent class",
      "class Person:",
      "    def __init__(self, name, age):",
      "        self.name = name",
      "        self.age  = age",
      "",
      "    def display_person(self):",
      "        print(f'Name: {self.name}, Age: {self.age}')",
      "",
      "# Child class — has its own __init__, uses super() to init parent",
      "class Student(Person):",
      "    def __init__(self, name, age, roll_no):",
      "        super().__init__(name, age)  # initialize parent attributes",
      "        self.roll_no = roll_no       # child-specific attribute",
      "",
      "    def display_student(self):",
      "        print(f'Roll Number: {self.roll_no}')",
      "",
      "s1 = Student('Ali', 16, 101)",
      "s1.display_person()   # works — parent attrs initialized",
      "s1.display_student()  # works — child attr"
    ],
    "description": "3.2 — Inheritance with super()"
  },

